    "@next/mdx": "^16.1.6",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "@types/mdx": "^2.0.13",
    "lucide-react": "^0.575.0",
    "next": "^16.2.4",
    "next-intl": "^4.8.3",
