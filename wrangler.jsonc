{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "portfolio",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"vectorize": [
		{
			"binding": "PORTFOLIO_VECTORIZE",
			"index_name": "portfolio-index",
			"remote": true
		}
	]
}